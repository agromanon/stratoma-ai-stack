# ═══════════════════════════════════════════════════════════════
# STRATOMA AI STACK — Environment Variables
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# ─── AI / LLM ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENROUTER_API_KEY=sk-or-v1-...
MINIMAX_API_KEY=...

# ─── Paperclip ─────────────────────────────────────────────────
PAPERCLIP_DB_PASSWORD=changeme_paperclip

# ─── n8n ───────────────────────────────────────────────────────
N8N_DB_PASSWORD=changeme_n8n
N8N_HOST=n8n.yourdomain.com
N8N_PROTOCOL=https
N8N_WEBHOOK_URL=https://n8n.yourdomain.com/
N8N_ENCRYPTION_KEY=generate_random_32chars_here
N8N_API_KEY=your_n8n_api_key

# ─── Supabase ──────────────────────────────────────────────────
SUPABASE_DB_PASSWORD=changeme_supabase
SUPABASE_JWT_SECRET=your_jwt_secret_min_32_chars
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_URL=https://db.yourdomain.com

# ─── GitHub ────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_...

# ─── Coolify (if using) ────────────────────────────────────────
COOLIFY_ACCESS_TOKEN=1|...
COOLIFY_BASE_URL=https://coolify.yourdomain.com

# ─── Telegram (OpenClaw) ───────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456789:AAA...

# ═══════════════════════════════════════════════════════════════
# EXTERNAL SAAS INTEGRATIONS
# ═══════════════════════════════════════════════════════════════

# ─── GoHighLevel (GHL) — CRM central ───────────────────────────
# Obtener en: GHL > Settings > Business Profile > API Keys
GHL_API_KEY=pit-...
# Location ID: GHL > Settings > Business Info (parte inferior)
GHL_LOCATION_ID=your_location_id
# URL base del location
GHL_LOCATION_URL=https://app.gohighlevel.com/v2/location/your_location_id

# ─── Gmail / Google Workspace ──────────────────────────────────
# Para emails comerciales y transaccionales
# App Password: Google Account > Security > 2FA > App passwords
GMAIL_ADDRESS=comercial@yourdomain.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
# Google Workspace domain
GOOGLE_WORKSPACE_DOMAIN=yourdomain.com
# OAuth (para n8n + GWS CLI)
GOOGLE_OAUTH_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-...

# ─── WhatsApp vía GHL AppLevel (comunicación directa 1:1) ──────
# Conectado al CRM: conversaciones bidireccionales con leads
# Configurar en: GHL > Settings > Integrations > WhatsApp
# No requiere credenciales adicionales si ya tienes GHL_API_KEY
# El número de WhatsApp conectado via AppLevel:
GHL_WHATSAPP_NUMBER=+34600000000

# ─── WhatsApp Meta API Oficial (comunicaciones masivas) ────────
# Para broadcasts, campañas y notificaciones a escala
# Obtener en: Meta Business Suite > WhatsApp > API
META_WHATSAPP_TOKEN=EAA...
META_WHATSAPP_PHONE_ID=your_phone_number_id
META_WHATSAPP_BUSINESS_ACCOUNT_ID=your_waba_id
# Webhook verify token (lo defines tú)
META_WHATSAPP_WEBHOOK_SECRET=your_webhook_secret

# ─── Evolution API (WhatsApp self-hosted, alternativa a Meta) ──
# Si usas Evolution API en lugar de Meta API directamente
EVOLUTION_API_URL=https://evolution.yourdomain.com
EVOLUTION_API_TOKEN=your_evolution_token
EVOLUTION_INSTANCE_ID=your_instance_id

# ─── Misc ──────────────────────────────────────────────────────
TIMEZONE=Europe/Madrid
SITE_URL=https://yourdomain.com
